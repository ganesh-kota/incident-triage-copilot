# ============================================================
# Incident Triage Copilot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#
# For mock mode (no LLM needed): python run_demo.py --mock
# ============================================================

# --- LLM Provider ---
# Supports: openai, azure_openai
LLM_PROVIDER=azure_openai

# For Azure OpenAI / Azure AI Foundry:
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# For standard OpenAI (set LLM_PROVIDER=openai):
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# --- MCP Server Transport ---
# stdio  = servers run as child processes (local dev)
# sse    = servers run as HTTP endpoints (production)
MCP_TRANSPORT=stdio

# --- Observability ---
LOG_LEVEL=INFO
ENABLE_TRACING=false
